      <span style="display:inline-block;padding:3px 10px;border-radius:10px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;background:rgba(0,0,0,.05);color:${p.sc};">${p.status}</span>
      ${flagsHtml ? `<div style="margin-top:7px;display:flex;gap:4px;flex-wrap:wrap;">${flagsHtml}</div>` : ''}
    </div>
    <div class="dp-sec">
      <div class="dp-lbl">Visit Info</div>
      <div class="dp-row"><div class="dp-key">Chief Complaint</div><div class="dp-val">${p.cc}</div></div>
      <div class="dp-row"><div class="dp-key">Vitals</div><div class="dp-val">${p.vitals}</div></div>
    </div>
    <div class="dp-sec">
      <div class="dp-lbl">Nurse Actions</div>
      <div class="dp-actions">${actsHtml}</div>
    </div>
  `;
  document.getElementById('tabDet').click();
}

document.querySelectorAll('.appt').forEach(appt => {
  appt.addEventListener('click', () => selectAppt(appt.dataset.id, appt));
});

// Tabs
const tabDet = document.getElementById('tabDet');
const tabAlt = document.getElementById('tabAlt');

tabDet.addEventListener('click', () => {
  tabDet.classList.add('on'); tabAlt.classList.remove('on');
  dpEmpty.style.display   = dpContent.innerHTML ? 'none' : 'flex';
});

tabAlt.addEventListener('click', () => {
  tabAlt.classList.add('on'); tabDet.classList.remove('on');
  dpEmpty.style.display = 'none';
  dpContent.innerHTML = `
    <div style="margin-bottom:12px;font-family:var(--cond);font-size:14px;font-weight:600;">Active Alerts</div>
    <div class="al-item r"><span class="al-icon">🔴</span><div class="al-body"><div class="al-title">Critical Result — Harris, Linda (Lab)</div><div class="al-meta">K+ 6.2 mEq/L · Draw in progress · Notify Snyder</div></div><span class="al-act">Notify →</span></div>
    <div class="al-item a"><span class="al-icon">⚠️</span><div class="al-body"><div class="al-title">Unsigned Note — Chen, Robert (PA-C)</div><div class="al-meta">Snyder 8:40 AM visit · Note not signed</div></div><span class="al-act">Flag →</span></div>
    <div class="al-item a"><span class="al-icon">💊</span><div class="al-body"><div class="al-title">eMAR Refusal — Torres, Luis</div><div class="al-meta">Sertraline 100mg morning dose refused</div></div><span class="al-act">Document</span></div>
    <div class="al-item b"><span class="al-icon">🚶</span><div class="al-body"><div class="al-title">Walk-In — Carter, Sandra (Lab)</div><div class="al-meta">UA + Culture · No order on file yet</div></div><span class="al-act">Create Order</span></div>
  `;
});

// Scroll sync: schedules drives time gutter
const schedScroll = document.getElementById('schedScroll');
const tgutter     = document.getElementById('tgutter');
schedScroll.addEventListener('scroll', () => { tgutter.scrollTop = schedScroll.scrollTop; });

// Scroll to ~9am on load (120px from top) and auto-select Ramirez
setTimeout(() => {
  schedScroll.scrollTop = 90;
  const el = document.getElementById('pac4el');
  if (el) selectAppt('pac4', el);
}, 100);

// View toggle
document.querySelectorAll('.vtog-btn').forEach(b => {
  b.addEventListener('click', () => {
    document.querySelectorAll('.vtog-btn').forEach(x => x.classList.remove('on'));
    b.classList.add('on');
  });
});
</script>
</body>
</html>
