<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nurse — Multi-Schedule View</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Sans+Condensed:wght@500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:      #f4f6fa;
  --surf:    #ffffff;
  --surf2:   #f0f2f7;
  --surf3:   #e6eaf3;
  --bdr:     #d0d6e8;
  --bdr2:    #b8c2d8;
  --blue:    #2b7de9;
  --blue-dk: #1a5fb8;
  --green:   #1fa86e;
  --green-dk:#15784d;
  --amber:   #c4780a;
  --red:     #c8324c;
  --purple:  #7254cc;
  --teal:    #1a9e92;
  --text:    #1a2035;
  --text2:   #4a5878;
  --text3:   #7a8aaa;
  --font:    'IBM Plex Sans', sans-serif;
  --mono:    'IBM Plex Mono', monospace;
  --cond:    'IBM Plex Sans Condensed', sans-serif;

  /* Provider accent colors */
  --pac:  #2b7de9;
  --np:   #7254cc;
  --flu:  #1a9e92;
  --lab:  #c4780a;

  /* 1 minute = 2px */
  --ppm: 2px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  height: 100%;
  font-family: var(--font);
  font-size: 13px;
  color: var(--text);
  background: var(--bg);
  overflow: hidden;
}

/* ─── Shell: topbar + everything below ─────────────────────────── */
.shell {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* ─── Topbar ────────────────────────────────────────────────────── */
.topbar {
  flex: 0 0 44px;
  display: flex;
  align-items: center;
  padding: 0 16px;
  gap: 12px;
  background: var(--surf);
  border-bottom: 1px solid var(--bdr);
  z-index: 50;
}
.tb-logo {
  font-family: var(--cond); font-weight: 600; font-size: 14px;
  letter-spacing: .08em; text-transform: uppercase; color: var(--blue);
  padding-right: 14px; border-right: 1px solid var(--bdr);
}
.tb-space { flex: 1; }
.tb-date {
  display: flex; align-items: center; gap: 8px;
  padding: 0 12px; border-right: 1px solid var(--bdr);
}
.tb-nav {
  background: var(--surf2); border: 1px solid var(--bdr); border-radius: 4px;
  color: var(--text2); padding: 3px 9px; font-size: 12px; cursor: pointer;
}
.tb-nav:hover { background: var(--surf3); }
.tb-today {
  background: var(--blue); color: #fff; border: none; border-radius: 4px;
  padding: 3px 10px; font-size: 11px; font-weight: 600; cursor: pointer;
}
.tb-cur {
  font-family: var(--cond); font-size: 13px; font-weight: 600;
  min-width: 175px; text-align: center;
}
.tb-user { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text2); }
.tb-avatar {
  width: 26px; height: 26px; border-radius: 50%; background: var(--red);
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 700; color: #fff;
}
.tb-role { font-size: 9px; color: var(--text3); font-family: var(--mono); text-transform: uppercase; letter-spacing: .07em; }
.tb-btn {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 5px 10px; border-radius: 4px;
  border: 1px solid var(--bdr); background: var(--surf);
  font-size: 11px; font-weight: 500; color: var(--text2); cursor: pointer;
}
.tb-btn:hover { border-color: var(--blue); color: var(--blue); }

/* ─── Toolbar ───────────────────────────────────────────────────── */
.toolbar {
  flex: 0 0 38px;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0 14px;
  background: var(--surf);
  border-bottom: 1px solid var(--bdr);
}
.vtog {
  display: flex; gap: 1px;
  background: var(--surf3); border: 1px solid var(--bdr); border-radius: 5px; padding: 2px;
}
.vtog-btn {
  padding: 3px 10px; border-radius: 3px; font-size: 11px;
  cursor: pointer; color: var(--text2); transition: all .1s;
}
.vtog-btn.on { background: var(--blue); color: #fff; font-weight: 600; }
.tl-sp { flex: 1; }
.tl-info { font-size: 11px; color: var(--text3); }
.tl-info b { color: var(--text2); }

/* ─── Provider header strip ─────────────────────────────────────── */
.prov-strip {
  flex: 0 0 auto;
  display: grid;
  grid-template-columns: 52px repeat(4, 1fr) 290px;
  background: var(--surf);
  border-bottom: 2px solid var(--bdr);
}
.ps-gutter { border-right: 1px solid var(--bdr); }
.ps-col {
  padding: 7px 12px;
  border-right: 1px solid var(--bdr);
}
.ps-col:nth-child(5) { border-right: none; } /* last sched col before detail panel */
.ps-detail-header {
  padding: 7px 12px;
  border-left: 1px solid var(--bdr);
  font-family: var(--mono); font-size: 9px; font-weight: 500;
  text-transform: uppercase; letter-spacing: .1em; color: var(--text3);
  display: flex; align-items: center; gap: 6px;
}
.ps-provider { display: flex; align-items: center; gap: 7px; margin-bottom: 4px; }
.ps-dot { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }
.ps-name { font-size: 11px; font-weight: 600; line-height: 1.2; }
.ps-role { font-size: 9px; color: var(--text3); font-family: var(--mono); text-transform: uppercase; letter-spacing: .06em; }
.ps-stats { display: flex; gap: 10px; flex-wrap: wrap; }
.ps-stat { font-size: 9px; color: var(--text3); }
.ps-stat b { font-family: var(--mono); font-weight: 600; }
.ps-stat b.g { color: var(--green); }
.ps-stat b.a { color: var(--amber); }
.ps-stat b.r { color: var(--red); }
.ps-stat b.t { color: var(--teal); }
.ps-stat b.p { color: var(--purple); }

/* ─── Main grid area ────────────────────────────────────────────── */
.grid-area {
  flex: 1 1 0;          /* takes all remaining vertical space */
  display: flex;
  overflow: hidden;
  min-height: 0;        /* critical — allows flex child to shrink below content */
}

/* Time gutter — fixed, non-scrolling horizontally */
.time-gutter {
  flex: 0 0 52px;
  overflow: hidden;     /* hides scrollbar but scrollTop is driven by JS */
  background: var(--surf2);
  border-right: 1px solid var(--bdr);
  position: relative;
}
.tg-inner {
  height: 960px;        /* same as sched-inner */
  position: relative;
}
.tl {
  position: absolute;
  right: 6px;
  font-family: var(--mono);
  font-size: 9px;
  color: var(--text3);
  transform: translateY(-50%);
  white-space: nowrap;
  user-select: none;
}
.tl.h { font-weight: 600; color: var(--text2); }

/* Schedules scroll wrapper */
.scheds-scroll {
  flex: 1 1 0;
  overflow-y: auto;
  overflow-x: hidden;
  min-height: 0;
}
.scheds-inner {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  height: 960px;
  position: relative;
}

/* Individual schedule column */
.sc {
  position: relative;
  border-right: 1px solid var(--bdr);
  overflow: hidden;
}
.sc:last-child { border-right: none; }

/* Hour / half-hour gridlines */
.hl {
  position: absolute; left: 0; right: 0; height: 1px;
  background: var(--bdr); pointer-events: none; z-index: 0;
}
.hl.half { background: #eaeff8; }

/* NOW line */
.now-line {
  position: absolute; left: 0; right: 0; height: 2px;
  background: var(--red); z-index: 8; pointer-events: none;
}
.now-line::before {
  content: '';
  position: absolute; left: -1px; top: -3px;
  width: 7px; height: 7px; border-radius: 50%; background: var(--red);
}

/* Unavailable / lunch shading */
.unavail {
  position: absolute; left: 0; right: 0; z-index: 1;
  background: var(--surf2);
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; color: var(--text3); font-style: italic;
  border-top: 1px solid var(--bdr); border-bottom: 1px solid var(--bdr);
}
.lunch {
  position: absolute; left: 0; right: 0; z-index: 1;
  background: repeating-linear-gradient(
    45deg, transparent, transparent 5px,
    rgba(0,0,0,.03) 5px, rgba(0,0,0,.03) 10px
  );
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; color: var(--text3); font-style: italic;
  border-top: 1px solid var(--bdr); border-bottom: 1px solid var(--bdr);
}

/* Appointment block */
.appt {
  position: absolute;
  left: 3px; right: 3px;
  border-radius: 4px;
  padding: 3px 6px;
  cursor: pointer;
  border-left: 3px solid transparent;
  overflow: hidden;
  z-index: 2;
  transition: box-shadow .12s, filter .12s;
}
.appt:hover {
  z-index: 10;
  box-shadow: 0 2px 8px rgba(0,0,0,.14);
  filter: brightness(.97);
}
.appt.sel {
  z-index: 12;
  box-shadow: 0 0 0 2px var(--blue);
}

.a-name {
  font-size: 10px; font-weight: 600;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  line-height: 1.3;
}
.a-sub {
  font-size: 9px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  opacity: .8; line-height: 1.3;
}
.a-dem {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 500;
  color: var(--text3);
  margin-left: 3px;
}
.a-flags { display: flex; gap: 2px; flex-wrap: wrap; margin-top: 2px; }
.af {
  font-size: 8px; padding: 0 4px; border-radius: 5px;
  border: 1px solid; font-weight: 700; white-space: nowrap; line-height: 1.4;
}
.af-r { color: var(--red);    border-color: rgba(200,50,76,.3);  background: rgba(200,50,76,.08); }
.af-a { color: var(--amber);  border-color: rgba(196,120,10,.3); background: rgba(196,120,10,.08); }
.af-g { color: var(--green);  border-color: rgba(31,168,110,.3); background: rgba(31,168,110,.08); }
.af-p { color: var(--purple); border-color: rgba(114,84,204,.3); background: rgba(114,84,204,.08); }
.af-n { color: var(--text3);  border-color: var(--bdr);          background: var(--surf2); }

/* Status color schemes */
.st-out  { background: rgba(26,158,146,.10); border-left-color: var(--teal);   color: #0d2e2b; }
.st-room { background: rgba(31,168,110,.14); border-left-color: var(--green);  color: #0a2618; }
.st-in   { background: rgba(196,120,10,.11); border-left-color: var(--amber);  color: #2e1800; }
.st-sch  { background: rgba(43,125,233,.08); border-left-color: var(--blue);   color: #0d1f40; }
.st-ns   { background: rgba(200,50,76,.08);  border-left-color: var(--red);    color: #350a14; opacity: .6; }
.st-walk { background: rgba(114,84,204,.10); border-left-color: var(--purple); color: #1a0e3a; }
.st-open { background: rgba(43,125,233,.03); border-left-color: #d0d6e8;       color: var(--text3);
           border: 1px dashed var(--bdr2); border-left: 3px dashed var(--bdr2); }
.st-prog { background: rgba(31,168,110,.18); border-left-color: var(--green);  color: #0a2618; }

/* ─── Detail panel ──────────────────────────────────────────────── */
.detail-panel {
  flex: 0 0 290px;
  display: flex;
  flex-direction: column;
  border-left: 1px solid var(--bdr);
  background: var(--surf);
  overflow: hidden;
}
.dp-tabs {
  flex: 0 0 auto;
  display: flex;
  border-bottom: 1px solid var(--bdr);
}
.dp-tab {
  flex: 1; padding: 9px 4px; text-align: center;
  font-size: 11px; font-weight: 500; cursor: pointer;
  color: var(--text2); border-bottom: 2px solid transparent;
}
.dp-tab.on { color: var(--blue); border-bottom-color: var(--blue); }
.dp-bdg {
  display: inline-block; background: var(--red); color: #fff;
  border-radius: 8px; padding: 0 5px; font-size: 9px; margin-left: 3px; vertical-align: middle;
}
.dp-body { flex: 1; overflow-y: auto; padding: 12px 14px; }
.dp-empty {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; height: 180px; color: var(--text3); gap: 8px; text-align: center;
}
.dp-empty-icon { font-size: 26px; opacity: .3; }
.dp-empty-txt { font-size: 11px; }

/* Detail content */
.dp-prov-tag {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 9px; font-weight: 700; text-transform: uppercase;
  letter-spacing: .06em; padding: 2px 8px; border-radius: 10px;
  background: rgba(0,0,0,.05); margin-bottom: 8px;
}
.dp-head { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 12px; }
.dp-av {
  width: 34px; height: 34px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 700; color: #fff; flex-shrink: 0;
}
.dp-name { font-size: 13px; font-weight: 600; margin-bottom: 2px; }
.dp-meta { font-size: 10px; color: var(--text2); }
.dp-time { font-family: var(--mono); font-size: 9px; color: var(--text3); margin-top: 2px; }

.dp-sec { margin-bottom: 13px; }
.dp-lbl {
  font-family: var(--mono); font-size: 9px; color: var(--text3);
  text-transform: uppercase; letter-spacing: .12em; margin-bottom: 5px;
  display: flex; align-items: center; gap: 6px;
}
.dp-lbl::after { content: ''; flex: 1; height: 1px; background: var(--bdr); }

.dp-row {
  display: flex; gap: 6px; padding: 4px 0;
  border-bottom: 1px solid var(--bdr); font-size: 11px;
}
.dp-row:last-child { border-bottom: none; }
.dp-key { color: var(--text3); font-size: 10px; min-width: 72px; flex-shrink: 0; }
.dp-val { color: var(--text); font-weight: 500; flex: 1; }
.dp-val.r { color: var(--red); }
.dp-val.a { color: var(--amber); }
.dp-val.g { color: var(--green); }

.dp-actions { display: flex; flex-direction: column; gap: 5px; }
.da-btn {
  width: 100%; padding: 7px 10px; border-radius: 5px;
  font-size: 11px; font-weight: 500; cursor: pointer;
  border: 1px solid var(--bdr2); background: var(--surf2); color: var(--text);
  transition: all .1s; text-align: center;
}
.da-btn:hover { border-color: var(--blue); color: var(--blue); }
.da-btn.pri { background: var(--blue); border-color: var(--blue); color: #fff; }
.da-btn.pri:hover { background: var(--blue-dk); }
.da-btn.grn { background: var(--green); border-color: var(--green); color: #fff; }
.da-btn.grn:hover { background: var(--green-dk); }
.da-btn.amb { background: rgba(196,120,10,.1); border-color: rgba(196,120,10,.4); color: var(--amber); }

/* Alert items */
.al-item {
  display: flex; align-items: flex-start; gap: 8px;
  padding: 8px 10px; background: var(--surf2); border: 1px solid var(--bdr);
  border-radius: 5px; margin-bottom: 6px; cursor: pointer;
  border-left: 3px solid var(--bdr2);
}
.al-item.r { border-left-color: var(--red); }
.al-item.a { border-left-color: var(--amber); }
.al-item.b { border-left-color: var(--blue); }
.al-icon { font-size: 13px; flex-shrink: 0; }
.al-body { flex: 1; }
.al-title { font-weight: 600; font-size: 11px; margin-bottom: 2px; }
.al-meta { font-size: 10px; color: var(--text3); }
.al-act { font-size: 10px; color: var(--blue); font-weight: 600; cursor: pointer; white-space: nowrap; }

/* ─── Legend ────────────────────────────────────────────────────── */
.legend {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--surf); border-top: 1px solid var(--bdr);
  padding: 5px 16px; display: flex; align-items: center; gap: 14px; z-index: 200; flex-wrap: wrap;
}
.lg-title { font-family: var(--cond); font-size: 9px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--text3); }
.lg-item { display: flex; align-items: center; gap: 4px; font-size: 10px; color: var(--text2); }
.lg-sw { width: 8px; height: 8px; border-radius: 2px; }

/* Scrollbar */
::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--bdr2); border-radius: 3px; }
</style>
</head>
