</div>

<!-- PROVIDER HEADER STRIP -->
<div class="prov-strip">
  <div class="ps-gutter"></div>

  <div class="ps-col">
    <div class="ps-provider">
      <div class="ps-dot" style="background:var(--pac)"></div>
