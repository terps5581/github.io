      <div class="ps-stat">NS <b class="r">1</b></div>
    </div>
  </div>

  <div class="ps-col">
    <div class="ps-provider">
      <div class="ps-dot" style="background:var(--np)"></div>
      <div><div class="ps-name">R. Patel, NP</div><div class="ps-role">Rm 7 · Rm 8</div></div>
    </div>
    <div class="ps-stats">
      <div class="ps-stat">Total <b>13</b></div>
